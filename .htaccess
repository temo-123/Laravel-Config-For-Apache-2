<IfModule mod_rewrite.c>
    RewriteEngine On

    # 1. Permanent 301 Redirect from the old domain (geo-climbing.ge) to the new domain (climbing.ge)
    RewriteCond %{HTTP_HOST} ^(www\.)?geo\-climbing\.ge$ [NC]
    RewriteRule ^(.*)$ http://climbing.ge [R=301,L]

    # 2. Permanent 301 Redirect from the register page to the login page
    RedirectPermanent /register http://climbing.ge/login
</IfModule>

# Block public web access to sensitive project files (like your database credentials)
RedirectMatch 403 ^/(\.env|\.git|composer\.(json|lock)|package\.(json|lock)|auth\.json)$
